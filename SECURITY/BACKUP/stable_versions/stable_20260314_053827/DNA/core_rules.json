{
  "version": "1.0.0",
  "immutable": true,
  "core_principles": {
    "capital_preservation": {
      "max_risk_per_trade": 0.02,
      "max_daily_drawdown": 0.05,
      "lock_profit_at_100": true,
      "locked_fund_protection": "2x_rule"
    },
    "evolution_safety": {
      "allow_mutation": true,
      "allow_crossover": true,
      "forbidden_mutations": [
        "max_risk_per_trade",
        "max_daily_drawdown",
        "evolution_protocol_version"
      ],
      "rollback_on_failure": true,
      "max_mutation_rate": 0.15
    },
    "trading_constraints": {
      "allowed_symbols": ["XAUUSD"],
      "hedging_mode": true,
      "anti_stacking": {
        "enabled": true,
        "min_layer_distance_pips": 5
      },
      "ghost_stop_loss": {
        "enabled": true,
        "broker_visibility": false,
        "execution_by": "EA"
      },
      "dynamic_trailing": {
        "start_lock_percent": 10,
        "max_lock_percent": 95,
        "increment_step": 5
      }
    },
    "session_management": {
      "max_trading_hours": 8,
      "mandatory_cooldown": 30,
      "new_session_reset": true
    }
  },
  "evolution_protocol": {
    "generation_method": "tournament_selection",
    "population_size": 100,
    "elite_preservation": 0.1,
    "mutation_probability": 0.1,
    "crossover_probability": 0.8
  }
}

