  "seven_strategies": [
    {
      "id": "S1",
      "name": "Breakout",
      "description": "Entry saat harga menembus level support/resistance kuat",
      "indicators": ["high_low_50", "atr"],
      "entry_condition": "close > resistance OR close < support",
      "weight": 1.0
    },
    {
      "id": "S2",
      "name": "Trend Following",
      "description": "Ikuti arah trend menggunakan MA crossover",
      "indicators": ["ma_fast", "ma_slow", "adx"],
      "entry_condition": "ma_fast > ma_slow AND adx > 25",
      "weight": 1.0
    },
    {
      "id": "S3",
      "name": "Momentum",
      "description": "Entry saat momentum kuat RSI + volume",
      "indicators": ["rsi", "volume", "macd"],
      "entry_condition": "rsi > 60 AND macd_signal > 0",
      "weight": 1.0
    },
    {
      "id": "S4",
      "name": "Mean Reversion",
      "description": "Entry saat harga terlalu jauh dari mean",
      "indicators": ["bollinger", "rsi"],
      "entry_condition": "close < lower_band OR close > upper_band",
      "weight": 1.0
    },
    {
      "id": "S5",
      "name": "Scalping Micro",
      "description": "Entry cepat dengan spread kecil, TP kecil SL kecil",
      "indicators": ["spread", "volatility", "tick_volume"],
      "entry_condition": "spread < 3 AND volatility > threshold",
      "weight": 1.0
    },
    {
      "id": "S6",
      "name": "Session Breakout",
      "description": "Entry saat pembukaan sesi London/NY dengan momentum",
      "indicators": ["session_open", "range_24h", "atr"],
      "entry_condition": "is_session_open AND range_expansion",
      "weight": 1.0
    },
    {
      "id": "S7",
      "name": "Support Resistance Bounce",
      "description": "Entry di dekat SR level dengan konfirmasi candle",
      "indicators": ["pivot_points", "candle_pattern", "rsi"],
      "entry_condition": "near_sr AND confirmation_candle",
      "weight": 1.0
    }
  ],

